# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=change-me-to-random-string
ALLOWED_TELEGRAM_USER_IDS=

# Setu Account Aggregator (get from https://bridge.setu.co/)
SETU_ENV=sandbox
SETU_AUTH_URL=https://accountservice.setu.co/v1/users/login
SETU_BASE_URL=https://fiu-sandbox.setu.co
SETU_CLIENT_ID=
SETU_CLIENT_SECRET=
SETU_PRODUCT_INSTANCE_ID=
SETU_REDIRECT_URL=https://setu.co/

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash

# App
PUBLIC_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://user:pass@localhost:5432/puppy
PORT=8000
