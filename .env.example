# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_SECRET_TOKEN=
ALLOWED_TELEGRAM_USER_IDS=

# Setu Account Aggregator (optional — PDF upload is the practical path)
# SETU_ENV=sandbox
# SETU_CLIENT_ID=
# SETU_CLIENT_SECRET=
# SETU_PRODUCT_INSTANCE_ID=

# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=
LLM_MODEL=gemini-2.5-flash

# App
PUBLIC_BASE_URL=http://localhost:8000
DATABASE_URL=postgresql://user:pass@localhost:5432/puppy
PORT=8000

# Job Tracker — scrapers (all true by default)
JOB_SCAN_ENABLED=true
GREENHOUSE_ENABLED=true
ASHBY_ENABLED=true
LINKEDIN_ENABLED=true
REMOTEOK_ENABLED=true
# ADZUNA_APP_ID=
# ADZUNA_API_KEY=

# Job Tracker — profile overrides (optional, overrides resume parse)
COMPANY_MIN_EMPLOYEES=500
PROFILE_EXPERIENCE_YEARS=
PROFILE_SKILLS=
PROFILE_TARGET_TITLES=
PROFILE_LOCATIONS=Bangalore,Remote
PROFILE_MIN_SALARY=2500000
